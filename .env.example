# Muse S serial number (e.g. Muse-XXXX)
# Find yours via Bluetooth settings or BrainFlow logs
MUSE_SERIAL_NUMBER=

# Muse S Athena BLE streaming preset.
#   (unset / empty) -> p1034 : EEG4 only (default ULTRA low-power; longest battery)
#   p1041           -> EEG8 + Optics16 + ACCGYRO + Battery (full low-power)
#   p20             -> EEG + ACCGYRO (no optics)
#   p21             -> EEG + PPG (BrainFlow-native default)
MUSE_PRESET=
